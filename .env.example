# Environment variables (NEVER commit this file!)
# Copy this to .env and fill in your MT5 credentials

# MT5 Account Credentials (Optional)
# If not set, bot will connect to already-logged-in MT5 terminal
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Example values:
# MT5_LOGIN=12345678
# MT5_PASSWORD=YourPassword123
# MT5_SERVER=ICMarkets-Demo
